# App settings
HOST=0.0.0.0
PORT=8000
SECRET_KEY=change-this-to-a-random-secret-key

# Admin password hash (Argon2)
# Generate with: cargo run --bin hash_password -- "your-password"
ADMIN_PASSWORD_HASH=

# Cloudflare R2 settings
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=unheard-artists-dev

# Database
DATABASE_URL=sqlite:./data/unheard.db?mode=rwc

# Upload limits
# - MAX_FILE_SIZE_MB: per-file limit (MB)
# - MAX_UPLOAD_SIZE_MB: total files per submission (MB)
MAX_FILE_SIZE_MB=100
MAX_UPLOAD_SIZE_MB=250

# Logging
RUST_LOG=info,tower_http=debug

# Optional: show ZIP artist image stamping
# If set, the artist picture inside each ZIP will be stamped with the artist name and logo.
ARTIST_LOGO_DIR=./assets/artist_logos
DEFAULT_LOGO_PATH=./assets/brand/moafunk.png
# OVERLAY_FONT_PATH=./assets/fonts/Shoika-font/Shoika\ Semi\ Bold.ttf

# Instagram API settings (optional)
# Required for posting show covers to Instagram
# Note: Generating a new token after changing permissions is required
# https://developers.facebook.com/apps/
# INSTAGRAM_ACCESS_TOKEN_DEV=your-long-lived-access-token
# INSTAGRAM_BUSINESS_ACCOUNT_ID_DEV=your-instagram-business-account-id
# Optional: for token refresh
# FACEBOOK_APP_ID=your-facebook-app-id
# FACEBOOK_APP_SECRET=your-facebook-app-secret

# OpenAI API settings (optional)
# Required for AI-generated artist bios from music descriptions
# Get your API key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Telegram bot (optional — bot disabled if token unset)
# Create via @BotFather, get chat ID from https://api.telegram.org/bot<TOKEN>/getUpdates
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# TELEGRAM_ADMIN_CHAT_ID=123456789
# TELEGRAM_TOPIC_ID=26
# TELEGRAM_INSTAGRAM_ACCOUNT=dev
# TELEGRAM_ARTIST_PREVIEW_HOUR=16  # Hour (0-23) Berlin time to send artist previews (default: 16)

# SoundCloud API (optional — disabled if client_id unset)
# Get credentials from https://soundcloud.com/you/apps
# SOUNDCLOUD_CLIENT_ID=your-client-id
# SOUNDCLOUD_CLIENT_SECRET=your-client-secret
# SOUNDCLOUD_ACCESS_TOKEN=your-access-token
