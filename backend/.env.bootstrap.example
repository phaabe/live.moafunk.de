# Copy to .env.bootstrap (gitignored) and set your Bitwarden Secrets Manager
# machine-account access token. dev-secrets.sh sources this automatically when
# BWS_ACCESS_TOKEN isn't already exported in your shell, so you don't have to
# re-export it every session.
#
# This file feeds dev-secrets.sh ONLY — the backend never reads it. Treat the token
# as a master credential: it can read every secret in the project. Never commit it.
BWS_ACCESS_TOKEN='0.00000000-0000-0000-0000-000000000000.xxxxxxxxxxxxxxxxxxxxxxxx:yyyyyyyyyyyyyyyyyyyyyy=='

# Only if your Bitwarden org is on the EU cloud or self-hosted (US cloud is the default):
# BWS_SERVER_URL='https://vault.bitwarden.eu'

# Keys to OMIT from the generated .env (space/comma-separated). Recommended: leave the
# Telegram bot off locally so it doesn't fight the production bot for getUpdates.
# DEV_SECRETS_EXCLUDE='TELEGRAM_BOT_TOKEN'
